// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

enum AdminStaffRole {
  OWNER
  ADMIN
  SUB_ADMIN
  MANAGER
  TEACHER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum InstructorStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  CLASS_6
  CLASS_7
  CLASS_8
  CLASS_9
  CLASS_10
  CLASS_11
  CLASS_12
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum EnrollmentSource {
  MANUAL_PAYMENT
  ADMIN_DIRECT
  LEGACY
}

enum EnrollmentRequestStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  CANCELLED
}

enum LessonType {
  VIDEO
  READING
  QUIZ
}

model User {
  id                         String              @id @default(cuid())
  fullName                   String
  email                      String              @unique
  phone                      String?
  passwordHash               String
  role                       UserRole            @default(STUDENT)
  adminRole                  AdminStaffRole?
  permissions                String[]            @default([])
  status                     UserStatus          @default(ACTIVE)
  emailVerifiedAt            DateTime?
  studentId                  String?             @unique
  classLevel                 Int?
  avatarUrl                  String?
  avatarPublicId             String?
  lastLoginAt                DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  sessions                   Session[]
  passwordResetOtps          PasswordResetOtp[]
  enrollments                Enrollment[]
  enrollmentRequests         EnrollmentRequest[] @relation("EnrollmentRequester")
  reviewedEnrollmentRequests EnrollmentRequest[] @relation("EnrollmentReviewer")
  grantedEnrollments         Enrollment[]        @relation("EnrollmentGranter")
  lessonProgress             LessonProgress[]
  quizAttempts               QuizAttempt[]
  counsellingBookings        CounsellingBooking[]
  notifications              Notification[]
  emailVerificationTokens    EmailVerificationToken[]
  learningWatchLock          LearningWatchLock?
  studentGameStats           StudentGameStats?
  studentGameSessions        StudentGameSession[]
  examEnrollments                ExamEnrollment[]
  examEnrollmentRequests         ExamEnrollmentRequest[] @relation("ExamEnrollmentRequester")
  reviewedExamEnrollmentRequests ExamEnrollmentRequest[] @relation("ExamEnrollmentReviewer")
  examAttempts                   ExamAttempt[]

  @@index([role])
  @@index([adminRole])
  @@index([status])
  @@index([studentId])
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  userId     String
  email      String
  otpHash    String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email, createdAt])
  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  userAgent  String?
  ipHash     String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LearningWatchLock {
  userId        String   @id
  sessionId     String
  lessonId      String
  courseSlug    String
  lessonSlug    String
  lastHeartbeat DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([lastHeartbeat])
}

model StudentGameStats {
  userId        String    @id
  wins          Int       @default(0)
  losses        Int       @default(0)
  draws         Int       @default(0)
  gamesPlayed   Int       @default(0)
  winStreak     Int       @default(0)
  bestWinStreak Int       @default(0)
  lastPlayedAt  DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentGameSession {
  id         String    @id @default(cuid())
  userId     String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model AuthRateLimit {
  key          String    @id
  attempts     Int       @default(0)
  windowStart  DateTime  @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([blockedUntil])
}

model Instructor {
  id              String           @id @default(cuid())
  slug            String           @unique
  fullName        String
  title           String
  shortBio        String
  bio             String
  avatarUrl       String
  coverUrl        String?
  specialty       String
  subjects        String[]
  expertise       String[]
  experienceYears Int              @default(0)
  studentsCount   Int              @default(0)
  coursesCount    Int              @default(0)
  rating          Float            @default(0)
  reviewCount     Int              @default(0)
  featured        Boolean          @default(false)
  displayOrder    Int              @default(0)
  status          InstructorStatus @default(ACTIVE)
  linkedIn        String?
  twitter         String?
  website         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([featured])
  @@index([displayOrder])
  @@index([specialty])
}

model ContactMessage {
  id        String               @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  role      String
  subject   String
  message   String
  source    String               @default("contact-page")
  status    ContactMessageStatus @default(NEW)
  ipHash    String?
  userAgent String?
  createdAt DateTime             @default(now())

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

enum CounsellingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum CounsellingPaymentStatus {
  UNQUOTED
  AWAITING_PAYMENT
  PROOF_SUBMITTED
  PAID
  WAIVED
}

enum NewsletterStatus {
  ACTIVE
  UNSUBSCRIBED
}


enum PopupCampaignStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PopupCampaignAudience {
  ALL
  GUESTS
  STUDENTS
}

enum PopupCampaignFrequency {
  ONCE_PER_CAMPAIGN
  ONCE_PER_SESSION
  EVERY_VISIT
}

enum TestimonialStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DocumentSubmissionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model CounsellingBooking {
  id              String            @id @default(cuid())
  fullName        String
  email           String
  phone           String
  educationLevel  String
  subjectInterest String
  preferredDate   DateTime
  preferredTime   String
  message         String?
  status          CounsellingStatus @default(PENDING)
  ipHash          String?
  userAgent       String?
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  meetingLink           String?
  counsellorNotes       String?
  sessionFee            Int?
  feeQuotedAt           DateTime?
  paymentStatus         CounsellingPaymentStatus @default(UNQUOTED)
  bkashSenderNumber     String?
  bkashTransactionId    String?
  paymentProofUrl       String?
  paymentProofPublicId  String?
  paymentProofFormat    String?
  paymentSubmittedAt    DateTime?
  paidAt                DateTime?
  paymentNote           String?
  archivedAt            DateTime?
  archivedById          String?
  files                 CounsellingFile[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([preferredDate])
  @@index([userId])
  @@index([paymentStatus])
  @@index([archivedAt, createdAt])
  @@index([subjectInterest])
  @@index([educationLevel])
}

model Course {
  id                 String              @id @default(cuid())
  slug               String              @unique
  title              String
  shortDescription   String
  category           String
  level              CourseLevel
  subject            String
  instructorName     String
  thumbnailUrl       String
  price              Int
  originalPrice      Int?
  durationMinutes    Int
  lessonCount        Int
  rating             Float               @default(0)
  reviewCount        Int                 @default(0)
  studentsCount      Int                 @default(0)
  featured           Boolean             @default(false)
  homepageOrder      Int                 @default(0)
  badge              String?
  status             CourseStatus        @default(DRAFT)
  publishedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  modules            CourseModule[]
  enrollments        Enrollment[]
  enrollmentRequests EnrollmentRequest[]

  @@index([status, category])
  @@index([status, level])
  @@index([status, featured])
  @@index([status, featured, homepageOrder])
  @@index([status, publishedAt])
  @@index([status, rating])
  @@index([category, level])
}

model CourseModule {
  id           String   @id @default(cuid())
  courseId     String
  title        String
  description  String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      Lesson[]

  @@unique([courseId, displayOrder])
  @@index([courseId, displayOrder])
}

model Lesson {
  id              String           @id @default(cuid())
  moduleId        String
  slug            String
  title           String
  description     String
  type            LessonType       @default(VIDEO)
  youtubeVideoId  String?
  durationSeconds Int              @default(0)
  content         String?
  displayOrder    Int              @default(0)
  isPreview       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  module          CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources       LessonResource[]
  progress        LessonProgress[]
  quiz            Quiz?

  @@unique([moduleId, slug])
  @@unique([moduleId, displayOrder])
  @@index([moduleId, displayOrder])
}

model LessonResource {
  id           String @id @default(cuid())
  lessonId     String
  title        String
  url          String
  displayOrder Int    @default(0)
  lesson       Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, displayOrder])
}

model Enrollment {
  id             String           @id @default(cuid())
  userId         String
  courseId       String
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())
  expiresAt      DateTime?
  completedAt    DateTime?
  lastAccessedAt DateTime?
  lastLessonId   String?
  source         EnrollmentSource @default(LEGACY)
  grantedById    String?
  grantNote      String?
  grantedAt      DateTime?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedBy      User?            @relation("EnrollmentGranter", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([userId, status])
  @@index([courseId, status])
  @@index([source, status])
  @@index([grantedById])
}

model EnrollmentRequest {
  id                   String                  @id @default(cuid())
  userId               String
  courseId             String
  status               EnrollmentRequestStatus @default(PENDING)
  studentPhone         String
  guardianPhone        String
  bkashSenderNumber    String
  bkashTransactionId   String
  paidAmount           Int
  paymentProofPublicId String
  paymentProofFormat   String
  paymentProofVersion  Int
  paymentProofBytes    Int
  studentNote          String?
  classLevel           Int
  reviewedById         String?
  reviewNote           String?
  reviewedAt           DateTime?
  submittedAt          DateTime                @default(now())
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  user                 User                    @relation("EnrollmentRequester", fields: [userId], references: [id], onDelete: Cascade)
  course               Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewedBy           User?                   @relation("EnrollmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@unique([bkashTransactionId])
  @@index([status, submittedAt])
  @@index([courseId, status])
  @@index([reviewedById])
}

model LessonProgress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  completed       Boolean   @default(false)
  completedAt     DateTime?
  watchedSeconds  Int       @default(0)
  lastPositionSec Int       @default(0)
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completed])
  @@index([lessonId])
}

model Quiz {
  id               String         @id @default(cuid())
  lessonId         String         @unique
  title            String
  description      String?
  passPercent      Int            @default(60)
  timeLimitSeconds Int?
  lesson           Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions        QuizQuestion[]
  attempts         QuizAttempt[]
}

model QuizQuestion {
  id           String       @id @default(cuid())
  quizId       String
  prompt       String
  explanation  String?
  displayOrder Int          @default(0)
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options      QuizOption[]

  @@unique([quizId, displayOrder])
  @@index([quizId, displayOrder])
}

model QuizOption {
  id           String       @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean      @default(false)
  displayOrder Int          @default(0)
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, displayOrder])
  @@index([questionId, displayOrder])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  total       Int
  percentage  Int
  passed      Boolean
  answers     Json
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId, submittedAt])
  @@index([quizId])
}

model NewsletterSubscriber {
  id        String           @id @default(cuid())
  email     String           @unique
  status    NewsletterStatus @default(ACTIVE)
  source    String           @default("footer")
  ipHash    String?
  userAgent String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}


model Testimonial {
  id           String            @id @default(cuid())
  fullName     String
  identity     String
  review       String
  imageUrl     String
  rating       Int               @default(5)
  featured     Boolean           @default(false)
  displayOrder Int               @default(0)
  status       TestimonialStatus @default(DRAFT)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, displayOrder])
  @@index([featured])
  @@index([createdAt])
}

model DocumentSubmission {
  id               String                   @id @default(cuid())
  fullName         String
  email            String
  phone            String?
  documentType     String
  fileUrl          String
  filePublicId     String?
  fileFormat       String?
  fileName         String?
  fileResourceType String?
  message          String?
  status           DocumentSubmissionStatus @default(PENDING)
  reviewNote       String?
  ipHash           String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([email, createdAt])
}

model CounsellingFile {
  id             String             @id @default(cuid())
  bookingId      String
  booking        CounsellingBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String
  fileKey        String
  uploadedByRole UserRole
  uploadedById   String
  uploadedByName String
  createdAt      DateTime           @default(now())

  @@index([bookingId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String
  category  String   @default("UPDATE") // ALERT | UPDATE | OFFER
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, archived, read, createdAt])
}

model Announcement {
  id         String   @id @default(cuid())
  text       String
  badge      String?
  ctaText    String?
  ctaLink    String?
  isActive   Boolean  @default(false)
  bgGradient String   @default("from-violet-600 to-indigo-600")
  textColor  String   @default("text-white")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
}

model SiteConfig {
  id                        String   @id @default("default")
  enrollmentGuideYoutubeUrl String?
  updatedAt                 DateTime @updatedAt
}

model PopupCampaign {
  id              String                 @id @default(cuid())
  title           String
  content         String
  badge           String?
  imageUrl        String?
  ctaText         String?
  ctaLink         String?
  status          PopupCampaignStatus    @default(DRAFT)
  audience        PopupCampaignAudience  @default(ALL)
  frequency       PopupCampaignFrequency @default(ONCE_PER_CAMPAIGN)
  startsAt        DateTime?
  endsAt          DateTime?
  priority        Int                    @default(0)

  // Premium promo fields
  originalPrice   Int?
  salePrice       Int?
  countdownEndsAt DateTime?
  theme           String                 @default("LIGHT")

  createdById     String
  updatedById     String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status, startsAt, endsAt])
  @@index([status, priority, createdAt])
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamEnrollmentStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ExamEnrollmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Exam {
  id                 String                  @id @default(cuid())
  slug               String                  @unique
  title              String
  code               String?                 @default("EXAM")
  description        String?
  bannerUrl          String?
  bannerPublicId     String?
  price              Int                     @default(0)
  originalPrice      Int?
  durationMinutes    Int                     @default(20)
  totalMarks         Int                     @default(25)
  negativeMarking    Float                   @default(0.0)
  status             ExamStatus              @default(DRAFT)
  startsAt           DateTime
  endsAt             DateTime
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  questions          ExamQuestion[]
  enrollments        ExamEnrollment[]
  enrollmentRequests ExamEnrollmentRequest[]
  attempts           ExamAttempt[]

  @@index([status, startsAt, endsAt])
  @@index([status, createdAt])
}

model ExamQuestion {
  id            String       @id @default(cuid())
  examId        String
  prompt        String
  imageUrl      String?
  imagePublicId String?
  explanation   String?
  displayOrder  Int          @default(0)
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  options       ExamOption[]

  @@unique([examId, displayOrder])
  @@index([examId, displayOrder])
}

model ExamOption {
  id           String       @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean      @default(false)
  displayOrder Int          @default(0)
  question     ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, displayOrder])
  @@index([questionId, displayOrder])
}

model ExamEnrollment {
  id         String               @id @default(cuid())
  userId     String
  examId     String
  status     ExamEnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime             @default(now())
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam       Exam                 @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId, status])
  @@index([examId, status])
}

model ExamEnrollmentRequest {
  id                   String                      @id @default(cuid())
  userId               String
  examId               String
  status               ExamEnrollmentRequestStatus @default(PENDING)
  bkashSenderNumber    String
  bkashTransactionId   String
  paidAmount           Int
  paymentProofPublicId String
  paymentProofFormat   String
  studentPhone         String?
  guardianPhone        String?
  classLevel           Int?
  studentNote          String?
  submittedAt          DateTime                    @default(now())
  reviewedById         String?
  reviewNote           String?
  reviewedAt           DateTime?
  user                 User                        @relation("ExamEnrollmentRequester", fields: [userId], references: [id], onDelete: Cascade)
  exam                 Exam                        @relation(fields: [examId], references: [id], onDelete: Cascade)
  reviewedBy           User?                       @relation("ExamEnrollmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, examId])
  @@unique([bkashTransactionId])
  @@index([status, submittedAt])
  @@index([examId, status])
  @@index([reviewedById])
}

model ExamAttempt {
  id           String      @id @default(cuid())
  userId       String
  examId       String
  score        Float
  total        Int
  correctQty   Int         @default(0)
  wrongQty     Int         @default(0)
  skippedQty   Int         @default(0)
  timeTakenSec Int         @default(0)
  answers      Json
  submittedAt  DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam         Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId, examId, submittedAt])
  @@index([examId])
}

